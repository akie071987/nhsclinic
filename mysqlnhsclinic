CREATE TABLE clinic(
clinicid BIGINT UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY,
name VARCHAR(255) NOT NULL,
address VARCHAR(255) NOT NULL
);
CREATE TABLE patient(
patientid BIGINT UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY,
name VARCHAR(255) NOT NULL,
address VARCHAR(255) NOT NULL,
clinicid BIGINT UNSIGNED NOT NULL,
FOREIGN KEY (clinicid) REFERENCES clinic(clinicid)
);
CREATE TABLE doctor(
doctorid BIGINT UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY,
clinicid BIGINT UNSIGNED NOT NULL,
name VARCHAR(255)NOT NULL,
speciality VARCHAR(255) NOT NULL,
FOREIGN KEY (clinicid) REFERENCES clinic(clinicid)
);
CREATE TABLE medication(
medicationid BIGINT UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY,
patientid BIGINT UNSIGNED NOT NULL,
doctorid BIGINT UNSIGNED NOT NULL,
drugname VARCHAR(255) NOT NULL,
diagnosis VARCHAR(255) NOT NULL,
FOREIGN KEY (patientid) REFERENCES patient(patientid),
FOREIGN KEY (doctorid) REFERENCES doctor(doctorid)
);
CREATE TABLE appointment(
appointmentid BIGINT UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY,
patientid BIGINT UNSIGNED NOT NULL,
doctorid BIGINT UNSIGNED NOT NULL,
appointmentdate VARCHAR(255) NOT NULL,
appointmenttime VARCHAR(255) NOT NULL,
note VARCHAR(255) NOT NULL,
FOREIGN KEY (patientid) REFERENCES patient(patientid),
FOREIGN KEY (doctorid) REFERENCES doctor(doctorid)
);
